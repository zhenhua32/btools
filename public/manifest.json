{
  "manifest_version": 3,
  "name": "BTools - 浏览器工具集",
  "version": "1.0.0",
  "description": "常用开发工具集合：文本对比、JSON格式化、编码转换等",
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "action": {
    "default_title": "打开 BTools"
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "host_permissions": ["https://*/*", "http://*/*"],
  "permissions": ["storage", "bookmarks", "contextMenus", "scripting"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
